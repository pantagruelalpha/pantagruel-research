---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Topics" sideBarActiveItemID="services">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Topics Covered</div>
  </div>

  <HorizontalCard
    title="Machine Learning for Finance"
    img="/post_img.webp"
    desc="Supervised and unsupervised learning applied to financial data: gradient boosting, neural networks, transformers and their pitfalls in low signal-to-noise environments."
    badge="CORE"
    url="/blog/"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Time Series Analysis & Forecasting"
    img="/post_img.webp"
    desc="Classical econometric models (ARIMA, GARCH) and modern deep learning approaches (LSTM, N-BEATS, TFT) for financial time series with a focus on non-stationarity."
    url="/blog/"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Portfolio Construction & Optimisation"
    img="/post_img.webp"
    desc="Mean-variance, Black-Litterman, Hierarchical Risk Parity and reinforcement learning approaches to dynamic asset allocation and risk budgeting."
    badge="CORE"
    url="/blog/"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Algorithmic Trading & Backtesting"
    img="/post_img.webp"
    desc="Strategy development, rigorous backtesting methodology, walk-forward testing, transaction cost modelling and avoiding the most common backtesting pitfalls."
    url="/blog/"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Risk Modelling & Credit"
    img="/post_img.webp"
    desc="Value-at-Risk, Expected Shortfall, credit scoring with ML, IFRS 9 probability of default models and tail-risk hedging strategies."
    url="/blog/"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="NLP & Alternative Data"
    img="/post_img.webp"
    desc="Sentiment analysis of earnings calls, central bank communications and news flows using large language models and classical NLP pipelines as alpha signals."
    url="/blog/"
  />
</BaseLayout>
