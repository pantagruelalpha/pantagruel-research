---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug"

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const last_posts = posts.slice(0, 3);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Welcome to 👋</div>
    <div class="text-5xl font-bold">Pantagruel Research</div>
    <div class="text-3xl py-3 font-bold">Quantitative Finance & Machine Learning</div>
    <div class="py-2">
      <text class="text-lg">
        A technical blog exploring the intersection of <b>machine learning</b>, <b>quantitative finance</b> and <b>data science</b>.
        Deep dives into portfolio optimization, time series forecasting, risk modelling and algorithmic trading strategies.
      </text>
    </div>
    <div class="mt-8">
      <a class="btn" href={`${base}/blog/`}> Read Articles</a>
      <a href={`${base}/projects`} class="btn btn-outline ml-5">
        View Research
      </a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">Featured Research Areas</div>
  </div>

  <HorizontalCard
    title="Time Series Forecasting with Deep Learning"
    img="/post_img.webp"
    desc="Applying transformer architectures and recurrent networks to predict financial time series, including equities, FX and volatility surfaces."
    url="/blog/"
    badge="ML"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Portfolio Optimisation & Risk"
    img="/post_img.webp"
    desc="Modern approaches to asset allocation: from mean-variance to reinforcement learning-based dynamic strategies and robust optimisation under uncertainty."
    url="/blog/"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Algorithmic Trading & Market Microstructure"
    img="/post_img.webp"
    desc="Statistical arbitrage, execution algorithms, limit order book modelling and the application of NLP to alternative data sources."
    url="/blog/"
    badge="QUANT"
  />

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Latest Articles</div>
  </div>

  {
    last_posts.map((post) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={"/blog/" + createSlug(post.data.title, post.slug)}
          target="_self"
          badge={post.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }
</BaseLayout>
